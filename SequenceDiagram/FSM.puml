@startuml
title Chinese Chess System - Finite State Machine

skinparam state {
  BackgroundColor<<auth>> LightBlue
  BackgroundColor<<menu>> LightGreen
  BackgroundColor<<view>> LightYellow
  BackgroundColor<<game>> Gold
  BackgroundColor<<end>> LightCoral
  BorderColor Black
  FontSize 14
  FontStyle bold
}

skinparam arrow {
  Color DarkSlateGray
  FontSize 11
}

[*] --> Connected : Open web /\nEstablish TCP

state Connected<<auth>>
state Lobby<<menu>>
state InProfile<<view>>
state InLeaderboard<<view>>
state WaitingMatch<<menu>>
state InGame<<game>>
state PostGame

Connected --> Connected : send(LOGIN/REGISTER) /\nrecv(ERROR)

Connected --> Lobby : recv(SUCCESS)[authenticated] /\nStore sessionID

Lobby --> InProfile : Click "Profile" /\nsend(USER_STATS)

Lobby --> InLeaderboard : Click "Leaderboard" /\nsend(LEADERBOARD)

' PvP: vào hàng đợi hoặc gửi lời mời
Lobby --> WaitingMatch : send(CHALLENGE)[target_online] /\nshowWaiting

' PvE: chơi với AI đi thẳng vào game
Lobby --> InGame : send(AI_GAME_REQUEST)[level_ok] /\ninitAI

InProfile --> Lobby : Click "Back"

InLeaderboard --> Lobby : Click "Back"

WaitingMatch --> Lobby : recv(DECLINE) /\nTimeout

WaitingMatch --> InGame : recv(GAME_START)[room_ready] /\nLoad board

InGame --> InGame : send(MOVE)[your_turn] /\nrecv(MOVE/AI_MOVE) /\nrecv(INVALID_MOVE)

InGame --> PostGame : recv(GAME_END)[finished]
InGame --> PostGame : send(RESIGN)

PostGame --> Lobby : Click "Exit"

PostGame --> WaitingMatch : send(REMATCH_REQUEST) /\nrecv(REMATCH_RESPONSE)[accept]

PostGame --> PostGame : send(REPLAY_REQUEST) /\nrecv(REPLAY_DATA)

Lobby --> Connected : send(LOGOUT) /\nClear session

@enduml